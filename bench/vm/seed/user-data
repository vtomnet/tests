#cloud-config
users:
  - name: user
    shell: /bin/bash
    groups: [wheel]
    sudo: ["ALL=(ALL) NOPASSWD:ALL"]
    lock_passwd: true
    ssh_authorized_keys:
      # TODO do not hardcode this
      - ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIBPyv6Ec5SvRJTgSfboIyZW7FV0cb0YQHWOBPc/gk+Uw thomas@morford.co

ssh_passwd: false
disable_root: true

package_update: true
packages:
  - git
  - curl

write_files:
  - path: /usr/local/bin/post-setup
    permissions: '0755'
    owner: root:root
    content: |
      #!/bin/sh
      set -eu
      echo "hello from cloud-init" >/etc/motd
      dnf -y copr enable atim/lazygit || true

runcmd:
  - [/usr/local/bin/post-setup]
